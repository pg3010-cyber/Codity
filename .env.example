# HTTP port for the API server + dashboard
PORT=4000

# Path to the SQLite database file (created automatically)
DB_PATH=./data/conveyor.db

# Secret used to sign user JWTs — change in any real deployment
JWT_SECRET=change-me-in-production

# Shared secret workers use to authenticate against the worker API
WORKER_TOKEN=local-worker-token

# Liveness tuning (all optional)
# WORKER_HEARTBEAT_TIMEOUT_MS=30000   workers silent longer are reaped
# CLAIM_TIMEOUT_MS=60000              claimed-but-never-started jobs are re-queued

# Worker process settings (read by worker/index.js)
API_URL=http://localhost:4000
WORKER_NAME=
WORKER_CONCURRENCY=4
# Comma separated queue names to subscribe to; empty = all queues
WORKER_QUEUES=
